generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ── ÉTABLISSEMENT ──────────────────────────────────────────
model Establishment {
  id            String   @id @default(uuid())
  name          String
  slug          String   @unique
  type          String   @default("FOYER") // FOYER, MAS, FAM, IME, EMP, MECS
  city          String   @default("")
  finess        String   @default("")
  phone         String   @default("")
  email         String   @default("")
  address       String   @default("")
  primaryColor  String   @default("#0f2b4a")
  accentColor   String   @default("#e85d04")
  logo          String   @default("")
  onboarded     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  users        User[]
  residents    Resident[]
  categories   Category[]
  objectives   Objective[]
  journal      JournalEntry[]
  planning     PlanningEvent[]
  presences    Presence[]
  vehicles     Vehicle[]
  documents    Document[]
}

// ── UTILISATEUR ────────────────────────────────────────────
model User {
  id              String   @id @default(uuid())
  establishmentId String
  establishment   Establishment @relation(fields: [establishmentId], references: [id], onDelete: Cascade)
  firstName       String   @default("")
  lastName        String   @default("")
  email           String   @default("")
  username        String   @unique
  passwordHash    String
  role            String   @default("educateur") // admin, educateur
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ── RÉSIDENT ───────────────────────────────────────────────
model Resident {
  id              String   @id @default(uuid())
  establishmentId String
  establishment   Establishment @relation(fields: [establishmentId], references: [id], onDelete: Cascade)
  firstName       String   @default("")
  lastName        String   @default("")
  photo           String   @default("")
  dob             String   @default("")
  gender          String   @default("")
  entryDate       String   @default("")
  status          String   @default("present") // present, absent, sortie, sorti
  room            String   @default("")
  referent        String   @default("")
  color           String   @default("#3b82f6")
  notes           String   @default("")
  emergencyContacts String @default("")
  // Enfant
  tuteur          String   @default("")
  tuteurTel       String   @default("")
  ecole           String   @default("")
  classe          String   @default("")
  organisme       String   @default("")
  dossier         String   @default("")
  // Adulte
  situationPro    String   @default("")
  ressources      String   @default("")
  organismeA      String   @default("")
  dossierA        String   @default("")
  situationAdmin  String   @default("")
  // Médical
  medecin         String   @default("")
  medecinTel      String   @default("")
  allergies       String   @default("")
  nss             String   @default("")
  // Objectifs (JSON array of objective IDs)
  objectifs       String   @default("[]")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  journal      JournalEntry[]
  planning     PlanningEvent[]
  presences    Presence[]
  documents    Document[]
}

// ── CATÉGORIE DE JOURNAL ──────────────────────────────────
model Category {
  id              String   @id @default(uuid())
  establishmentId String
  establishment   Establishment @relation(fields: [establishmentId], references: [id], onDelete: Cascade)
  name            String
  color           String   @default("#3b82f6")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  journal JournalEntry[]
}

// ── OBJECTIF ───────────────────────────────────────────────
model Objective {
  id              String   @id @default(uuid())
  establishmentId String
  establishment   Establishment @relation(fields: [establishmentId], references: [id], onDelete: Cascade)
  name            String
  description     String   @default("")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ── JOURNAL DE BORD ────────────────────────────────────────
model JournalEntry {
  id              String        @id @default(uuid())
  establishmentId String
  establishment   Establishment @relation(fields: [establishmentId], references: [id], onDelete: Cascade)
  residentId      String
  resident        Resident      @relation(fields: [residentId], references: [id], onDelete: Cascade)
  categoryId      String?
  category        Category?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  objectiveId     String?       @default("")
  content         String
  visibility      String        @default("equipe") // equipe, tous, confidentiel
  date            String
  createdBy       String        @default("")
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

// ── PLANNING ───────────────────────────────────────────────
model PlanningEvent {
  id              String        @id @default(uuid())
  establishmentId String
  establishment   Establishment @relation(fields: [establishmentId], references: [id], onDelete: Cascade)
  residentId      String?
  resident        Resident?     @relation(fields: [residentId], references: [id], onDelete: SetNull)
  title           String
  type            String        @default("activite") // activite, rdv, sortie, reunion, autre, vehicule
  date            String
  time            String        @default("")
  dateEnd         String        @default("")
  timeEnd         String        @default("")
  duration        String        @default("60")
  color           String        @default("#3b82f6")
  description     String        @default("")
  vehicle         String        @default("")
  destination     String        @default("")
  reservedBy      String        @default("")
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

// ── PRÉSENCES ──────────────────────────────────────────────
model Presence {
  id              String        @id @default(uuid())
  establishmentId String
  establishment   Establishment @relation(fields: [establishmentId], references: [id], onDelete: Cascade)
  residentId      String
  resident        Resident      @relation(fields: [residentId], references: [id], onDelete: Cascade)
  date            String        // YYYY-MM-DD
  status          String        @default("unknown") // present, absent, sortie, unknown
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([establishmentId, residentId, date])
}

// ── VÉHICULE ───────────────────────────────────────────────
model Vehicle {
  id              String        @id @default(uuid())
  establishmentId String
  establishment   Establishment @relation(fields: [establishmentId], references: [id], onDelete: Cascade)
  name            String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

// ── DOCUMENT ────────────────────────────────────────────────
model Document {
  id              String        @id @default(uuid())
  establishmentId String
  establishment   Establishment @relation(fields: [establishmentId], references: [id], onDelete: Cascade)
  residentId      String
  resident        Resident      @relation(fields: [residentId], references: [id], onDelete: Cascade)
  name            String
  category        String        @default("autre")
  size            Int           @default(0)
  mimeType        String        @default("")
  filePath        String        @default("")
  uploadedBy      String        @default("")
  createdAt       DateTime      @default(now())
}
